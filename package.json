{
  "name": "molt-city",
  "version": "0.1.0",
  "private": true,
  "description": "API-first SimCity-like hackathon simulation in Cerebral Valley.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @molt-city/api --filter @molt-city/web dev",
    "dev:api": "pnpm --filter @molt-city/api dev",
    "dev:web": "pnpm --filter @molt-city/web dev",
    "dev:sim": "pnpm --filter @molt-city/simulator dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "smoke:client": "tsx scripts/smoke-client.ts",
    "sim": "pnpm --filter @molt-city/simulator start"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.14"
  }
}
