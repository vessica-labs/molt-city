{
  "name": "molt-city",
  "version": "0.1.0",
  "private": true,
  "description": "API-first SimCity-like hackathon simulation in Cerebral Valley.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @molt-city/api run dev",
    "dev:web": "npm --workspace @molt-city/web run dev",
    "build": "npm run build --workspaces",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "smoke:client": "tsx scripts/smoke-client.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.14"
  }
}
