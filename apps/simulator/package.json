{
  "name": "@molt-city/simulator",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "@molt-city/client": "workspace:*",
    "@molt-city/shared": "workspace:*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "pnpm --filter @molt-city/shared build && pnpm --filter @molt-city/client build && tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  }
}
